# Local MLX model settings
# Start your MLX model server on the Mac host, then Docker services can reach it
# through host.docker.internal. If you run services without Docker, use
# http://localhost:8080/v1 instead.
LLM_BASE_URL=http://host.docker.internal:8080/v1
LLM_MODEL=LiquidAI/LFM2.5-1.2B-Instruct
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30

# Optional. Leave empty for local MLX if no key is required.
LLM_API_KEY=

# Service URLs for local Docker Compose networking
RAG_SERVICE_URL=http://rag-retrieval:8001
LLM_SERVICE_URL=http://llm-reasoning:8002
DATA_SERVICE_URL=http://mock-data:8003
SERVICE_TIMEOUT_SECONDS=45

# Retrieval settings
SOP_FILE_PATH=/app/document/SOP.md
RETRIEVAL_TOP_K=4
